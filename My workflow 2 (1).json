{
  "name": "My workflow 2",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 18 4 3 *"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [240, 300],
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "documentId": "YOUR_SHEET_ID_HERE",
        "sheetName": "Sheet1",
        "options": {}
      },
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [480, 300],
      "name": "Get row(s) in sheet"
    },
    {
      "parameters": {
        "sendTo": "={{ $json.Email }}",
        "subject": "Happy Holi",
        "emailType": "text",
        "message": "Dear {{ $json.Name }}, Happy Holi! and have a great day {{ $json.Message }}\n\nFrom [Your Name]",
        "options": {}
      },
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [720, 300],
      "name": "Send a message"
    }
  ],
  "connections": { ... same as before ... },
  "active": false,
  "settings": { ... },
  "versionId": "example-version-id",
  "meta": {},
  "id": "example-id",
  "tags": []
}
